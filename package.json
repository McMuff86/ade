{
  "name": "ade",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "author": "Adi Muff",
  "homepage": "https://github.com/McMuff86/ade",
  "desktopName": "com.adimuff.ade.desktop",
  "description": "ADE - agentic development environment (desktop workspace for CLI agents)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "pnpm run test:memory && pnpm run test:dispatch && pnpm run test:runtime && pnpm run test:backends && pnpm run test:orchestration && pnpm run test:orchestration-beta && pnpm run test:publication && pnpm run test:prompts && pnpm run test:repositories && pnpm run test:repository-inspector && pnpm run test:harness && pnpm run test:workspace-fs && pnpm run test:security",
    "test:memory": "tsx scripts/test-memory.ts",
    "test:dispatch": "tsx scripts/test-worker-dispatch.ts",
    "test:runtime": "tsx scripts/test-runtime-reliability.ts",
    "test:backends": "tsx scripts/test-execution-backends.ts",
    "test:wsl-backend": "tsx scripts/test-execution-backends.ts --wsl",
    "test:orchestration": "tsx scripts/test-orchestration.ts",
    "test:orchestration-beta": "tsx scripts/test-orchestration-beta.ts",
    "test:publication": "tsx scripts/test-publication.ts",
    "test:prompts": "tsx scripts/test-prompts.ts",
    "test:repositories": "tsx scripts/test-repository-scopes.ts",
    "test:repository-inspector": "tsx scripts/test-repository-inspector.ts",
    "test:harness": "tsx scripts/test-harness-credentials.ts",
    "test:workspace-fs": "tsx scripts/test-workspace-fs.ts",
    "test:security": "tsx scripts/test-security.ts",
    "test:electron": "pnpm run build && tsx scripts/test-electron-workflow.ts",
    "test:visual": "pnpm run build && tsx scripts/test-visual-regression.ts",
    "test:visual:update": "pnpm run build && tsx scripts/test-visual-regression.ts --update",
    "goal6:report": "tsx scripts/goal6-report.ts",
    "agents:codex": "tsx scripts/configure-codex-roster.ts",
    "verify": "pnpm run typecheck && pnpm test && pnpm run build && tsx scripts/test-electron-workflow.ts && tsx scripts/test-visual-regression.ts",
    "package:dir": "pnpm run build && electron-builder --win --x64 --dir",
    "package:win": "pnpm run build && electron-builder --win nsis --x64",
    "package:linux:dir": "pnpm run build && electron-builder --linux --x64 --dir --publish never",
    "package:linux": "pnpm run build && electron-builder --linux AppImage deb --x64 --publish never",
    "rebuild:pty": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.adimuff.ade",
    "productName": "ADE",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "agentic_coding_environment_icon.png",
      "artifactName": "ADE-${version}-${arch}-Setup.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "ade",
      "icon": "agentic_coding_environment_icon.png",
      "maintainer": "Adi Muff <McMuff86@users.noreply.github.com>",
      "category": "Development",
      "packageCategory": "devel",
      "syncDesktopName": true,
      "synopsis": "Desktop workspace for orchestrating CLI coding agents",
      "desktop": {
        "entry": {
          "Name": "ADE",
          "Comment": "Agentic development environment for CLI coding agents",
          "Keywords": "development;agents;terminal;git;"
        }
      },
      "artifactName": "ADE-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ADE",
      "uninstallDisplayName": "ADE"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^3.0.0",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^5.0.0",
    "pixelmatch": "^7.2.0",
    "playwright": "1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
