{
  "name": "ade",
  "version": "0.1.0",
  "private": true,
  "description": "ADE - agentic development environment (desktop workspace for CLI agents)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:memory": "tsx scripts/test-memory.ts",
    "test:dispatch": "tsx scripts/test-worker-dispatch.ts",
    "rebuild:pty": "electron-rebuild -f -w node-pty"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^3.0.0",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.1.0",
    "electron-vite": "^5.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
