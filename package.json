{
  "name": "ade",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "author": "Adi Muff",
  "description": "ADE - agentic development environment (desktop workspace for CLI agents)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "pnpm run test:memory && pnpm run test:dispatch && pnpm run test:runtime && pnpm run test:orchestration && pnpm run test:orchestration-beta && pnpm run test:security",
    "test:memory": "tsx scripts/test-memory.ts",
    "test:dispatch": "tsx scripts/test-worker-dispatch.ts",
    "test:runtime": "tsx scripts/test-runtime-reliability.ts",
    "test:orchestration": "tsx scripts/test-orchestration.ts",
    "test:orchestration-beta": "tsx scripts/test-orchestration-beta.ts",
    "test:security": "tsx scripts/test-security.ts",
    "test:electron": "pnpm run build && tsx scripts/test-electron-workflow.ts",
    "verify": "pnpm run typecheck && pnpm test && pnpm run build && tsx scripts/test-electron-workflow.ts",
    "package:dir": "pnpm run build && electron-builder --win --x64 --dir",
    "package:win": "pnpm run build && electron-builder --win nsis --x64",
    "rebuild:pty": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.adimuff.ade",
    "productName": "ADE",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "agentic_coding_environment_icon.png",
      "artifactName": "ADE-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "ADE",
      "uninstallDisplayName": "ADE"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^3.0.0",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "^5.0.0",
    "playwright": "1.61.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
